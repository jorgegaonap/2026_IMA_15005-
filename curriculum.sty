\newcommand{\curriculum}[2]{%
  \ifcsname cur@s@#1\endcsname
    \ifcsname cur@s@#2\endcsname
      \edef\cur@clave{curINT\csname cur@s@#1\endcsname\csname cur@s@#2\endcsname}%
      \ifcsname \cur@clave\endcsname
        \csname \cur@clave\endcsname
      \else
        \edef\cur@bc{curBASE\csname cur@s@#1\endcsname}%
        \ifcsname \cur@bc\endcsname \csname \cur@bc\endcsname \fi
      \fi
    \else
      \edef\cur@bc{curBASE\csname cur@s@#1\endcsname}%
      \ifcsname \cur@bc\endcsname \csname \cur@bc\endcsname \fi
    \fi
  \else
    \begin{tcolorbox}[colback=red!10!white,colframe=red!70!black,
      fonttitle=\bfseries,title={C\'{o}digo no encontrado}]
      La base \texttt{\detokenize{#1}} no existe.\\%
      Bases disponibles: \texttt{1\_B}, \texttt{1\_M}, \texttt{2\_B}, \texttt{2\_M}, \texttt{3\_B}, \texttt{3\_M}, \texttt{4\_B}, \texttt{4\_M}, \texttt{5\_B}, \texttt{6\_B}, \texttt{7\_B}, \texttt{8\_B}
    \end{tcolorbox}%
  \fi
}

